# ATLAS GSE - Variables de Entorno

# Base de datos (producción)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atlas?schema=public"

# NextAuth.js
NEXTAUTH_SECRET="minimo-32-caracteres-cambiar-en-produccion"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (opcional)
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-client-secret"

# Resend para emails (opcional)
RESEND_API_KEY="re_tu_api_key"
EMAIL_FROM="Atlas <noreply@tudominio.com>"

# Storage de documentos (obligatorio para uploads)
S3_REGION="us-east-1"
S3_BUCKET="atlas-documentos"
S3_ACCESS_KEY_ID="tu-access-key"
S3_SECRET_ACCESS_KEY="tu-secret-key"

# Rate limit distribuido con Upstash Redis (recomendado en SaaS)
UPSTASH_REDIS_REST_URL="https://<tu-instancia>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="tu-token-rest"

# Demo mode (deshabilitado por defecto en producción)
DEMO_MODE="false"
